# ── Supabase ────────────────────────────────────────────────────────────────────
# Project URL — found in Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service-role secret key — has full DB access, never expose this to clients.
# Found in Supabase dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Anthropic ───────────────────────────────────────────────────────────────────
# API key for Claude Haiku insight generation.
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── App config ──────────────────────────────────────────────────────────────────
# Target number of drinks per day used in goal-progress calculations and
# the Claude Haiku prompt. Adjust to match your use case (default: 8).
DAILY_DRINK_GOAL=8
