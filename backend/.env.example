# ── Supabase ────────────────────────────────────────────────────────────────────
# Project URL — found in Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service-role secret key — has full DB access, never expose this to clients.
# Found in Supabase dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Ollama ───────────────────────────────────────────────────────────────────────
# Base URL of your Ollama instance (local or remote).
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Model to use for insight generation. Must be pulled first: `ollama pull <model>`
# Recommended: llama3.2 (fast, good JSON adherence) or mistral
OLLAMA_MODEL=llama3.2

# ── App config ──────────────────────────────────────────────────────────────────
# Target number of drinks per day used in goal-progress calculations and
# the Ollama prompt. Adjust to match your use case (default: 8).
DAILY_DRINK_GOAL=8
