# ── Postgres ─────────────────────────────────────────────────────────────────────
# Standard libpq connection string for your Postgres server.
# Format: postgresql://user:password@host:port/dbname
# Example (local):  postgresql://postgres:secret@localhost:5432/drunk
# Example (remote): postgresql://postgres:secret@192.168.1.10:5432/drunk
DATABASE_URL=postgresql://user:password@localhost:5432/drunk

# ── Ollama ───────────────────────────────────────────────────────────────────────
# Base URL of your Ollama instance (local or remote).
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Model to use for insight generation. Must be pulled first: `ollama pull <model>`
# Recommended: llama3.2 (fast, good JSON adherence) or mistral
OLLAMA_MODEL=llama3.2

# ── App config ──────────────────────────────────────────────────────────────────
# Target number of drinks per day used in goal-progress calculations and
# the Ollama prompt. Adjust to match your use case (default: 8).
DAILY_DRINK_GOAL=8
